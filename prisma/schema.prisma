// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Genre {
  id     Int    @id
  nameZh String @map("name_zh")
  nameEn String @map("name_en")
  slug   String @unique

  movies MovieGenre[]

  @@map("genres")
}

model Movie {
  id           Int     @id
  title        String
  originalTitle String? @map("original_title")
  overview     String?
  posterPath   String?  @map("poster_path")
  backdropPath String?  @map("backdrop_path")
  releaseDate  String?  @map("release_date")
  voteAverage  Float?   @map("vote_average")
  voteCount    Int?     @map("vote_count")
  popularity   Float?
  runtime      Int?
  adult        Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  genres MovieGenre[]
  casts  MovieCast[]

  @@map("movies")
}

model MovieGenre {
  movieId Int   @map("movie_id")
  genreId Int   @map("genre_id")
  movie   Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre   Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
  @@map("movie_genres")
}

model Cast {
  id          Int     @id
  name        String
  profilePath String? @map("profile_path")

  movies MovieCast[]

  @@map("casts")
}

model MovieCast {
  movieId       Int     @map("movie_id")
  castId        Int     @map("cast_id")
  role          String  @default("actor")
  characterName String? @map("character_name")
  sortOrder     Int?    @default(0) @map("sort_order")

  movie Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  cast  Cast   @relation(fields: [castId], references: [id], onDelete: Cascade)

  @@id([movieId, castId, role])
  @@map("movie_casts")
}

// ─── Auth Models ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  hashedPassword String?  @map("hashed_password")
  role          String    @default("FREE") // FREE | PREMIUM
  subscriptionEndsAt DateTime? @map("subscription_ends_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  accounts Account[]
  sessions Session[]
  orders   Order[]

  @@map("users")
}

model Order {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  orderNo       String   @unique @map("order_no") // 商户订单号
  tradeNo       String?  @unique @map("trade_no") // 支付宝交易号
  amount        Float    // 金额（元）
  plan          String   // 套餐标识：monthly/yearly
  status        String   @default("PENDING") // PENDING/PAID/REFUNDED/CLOSED
  paidAt        DateTime? @map("paid_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("orders")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @map("refresh_token")
  access_token      String? @map("access_token")
  expires_at        Int?    @map("expires_at")
  token_type        String? @map("token_type")
  scope             String?
  id_token          String? @map("id_token")
  session_state     String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
